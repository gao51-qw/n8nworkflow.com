---
/**
 * 文章列表页面
 * 展示所有工作流文章和教程
 */

import MainLayout from '../layouts/MainLayout.astro';
import WorkflowGrid from '../components/workflow/WorkflowGrid.astro';
import Pagination from '../components/ui/Pagination.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import SortDropdown from '../components/ui/SortDropdown.astro';
import FilterBar from '../components/ui/FilterBar.astro';
import { getWorkflows } from '../lib/services/workflows';
import { getCategories } from '../lib/services/categories';

// 获取分页参数
const currentPage = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10));
const pageSize = 12;
const offset = (currentPage - 1) * pageSize;

// 获取排序参数
const sort = Astro.url.searchParams.get('sort') || 'date-desc';

// 获取所有工作流
let workflows = [];
let totalCount = 0;

try {
  const result = await getWorkflows({
    sort: sort,
    limit: pageSize,
    offset: offset,
  });
  workflows = result.workflows;
  totalCount = result.total;
} catch (error) {
  console.error('Error fetching workflows:', error);
}

// 获取分类用于筛选
let categories = [];
try {
  categories = await getCategories();
} catch (error) {
  console.error('Error fetching categories:', error);
}

// SEO 配置
const seoConfig = {
  title: 'All Workflow Articles - N8N Workflows',
  description: 'Browse all n8n workflow articles and tutorials. Learn from comprehensive guides and automation examples from the community.',
  canonical: '/articles',
};

// 面包屑导航
const breadcrumbItems = [
  { label: 'Articles' }
];

// 计算总页数
const totalPages = Math.ceil(totalCount / pageSize);
---

<MainLayout {...seoConfig}>
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <Breadcrumb items={breadcrumbItems} />

    <!-- Page Header -->
    <div class="mb-8">
      <div class="flex items-start gap-4 mb-4">
        <div class="flex-shrink-0 w-16 h-16 flex items-center justify-center bg-gradient-to-br from-blue-500 to-purple-600 rounded-lg shadow-lg">
          <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <div class="flex-1">
          <h1 class="text-3xl md:text-4xl font-black text-gray-900 dark:text-white mb-2">
            Workflow Articles & Tutorials
          </h1>
          <p class="text-lg text-gray-600 dark:text-gray-300">
            Comprehensive guides and examples to help you master n8n automation.
          </p>
        </div>
      </div>

      <!-- Stats Banner -->
      <div class="bg-gradient-to-r from-blue-50 to-purple-50 dark:from-gray-800 dark:to-gray-800 rounded-lg p-6 border border-blue-200 dark:border-gray-700">
        <div class="flex items-center gap-3">
          <svg class="w-8 h-8 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
          <div>
            <div class="text-2xl font-black text-gray-900 dark:text-white">
              {totalCount} Articles Available
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">
              Learn from community-contributed workflows and tutorials
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Filters -->
    <FilterBar categories={categories} currentPrice="all" currentComplexity="all" />

    <!-- Sort Bar -->
    <div class="flex items-center justify-between mb-6 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
      <div class="text-sm text-gray-600 dark:text-gray-400">
        Showing <strong class="text-gray-900 dark:text-white">{workflows.length}</strong> of <strong class="text-gray-900 dark:text-white">{totalCount}</strong> workflows
      </div>
      <SortDropdown currentSort={sort} />
    </div>

    <!-- Workflows Grid -->
    {workflows.length > 0 ? (
      <>
        <WorkflowGrid workflows={workflows} columns={3} />
        
        <!-- 分页 -->
        {totalPages > 1 && (
          <Pagination
            currentPage={currentPage}
            totalPages={totalPages}
            baseUrl="/articles"
          />
        )}
      </>
    ) : (
      <div class="text-center py-12">
        <svg class="w-16 h-16 mx-auto text-gray-400 dark:text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
          No articles available
        </h3>
        <p class="text-gray-600 dark:text-gray-400">
          Workflow articles will appear here once they're added.
        </p>
      </div>
    )}

    <!-- Info Section -->
    <div class="mt-12 bg-primary-50 dark:bg-gray-800 rounded-lg p-8 border border-primary-200 dark:border-gray-700">
      <h2 class="text-2xl font-black text-gray-900 dark:text-white mb-4">
        What You'll Find Here
      </h2>
      <div class="grid md:grid-cols-3 gap-6 text-sm text-gray-600 dark:text-gray-300">
        <div>
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <strong class="text-gray-900 dark:text-white">Step-by-Step Guides</strong>
          </div>
          <p>Detailed tutorials with screenshots and explanations for every step.</p>
          <div class="text-xs text-primary-600 dark:text-primary-400 font-medium mt-1">Easy to follow</div>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            <strong class="text-gray-900 dark:text-white">Real-World Examples</strong>
          </div>
          <p>Learn from practical automation scenarios used in production.</p>
          <div class="text-xs text-primary-600 dark:text-primary-400 font-medium mt-1">Battle-tested</div>
        </div>
        <div>
          <div class="flex items-center gap-2 mb-2">
            <svg class="w-5 h-5 text-primary-600 dark:text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            <strong class="text-gray-900 dark:text-white">Best Practices</strong>
          </div>
          <p>Tips and tricks from experienced n8n users and developers.</p>
          <div class="text-xs text-primary-600 dark:text-primary-400 font-medium mt-1">Expert knowledge</div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
